@model IEnumerable<Equipmenet_Management_Systen.Models.Department>

@{
    ViewData["Title"] = "Departments";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between mb-3">
        <h2>Department Management</h2>
        @if (User.IsInRole("Head"))
        {
            <a asp-action="Create" class="btn btn-primary btn-lg">
                <i class="bi bi-plus-lg"></i> Add Department
            </a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Department Name</th>
                        <th>Created Date</th>
                        @if (User.IsInRole("Head"))
                        {
                            <th>Action</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dept in Model)
                    {
                        <tr>
                            <td>@dept.Name</td>
                            <td>@dept.CreatedDate.ToString("dd/MM/yyyy")</td>
                            @if (User.IsInRole("Head"))
                            {
                                <td>
                                    <a asp-action="Edit" asp-route-id="@dept.Id" class="btn btn-warning btn-sm">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <form method="post" asp-action="Delete" asp-route-id="@dept.Id" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure?')">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info mt-3">
            No departments found. <a asp-action="Create">Create your first department</a>
        </div>
    }
</div>
