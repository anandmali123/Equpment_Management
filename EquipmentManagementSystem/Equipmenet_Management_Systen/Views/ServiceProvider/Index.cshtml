@model IEnumerable<Equipmenet_Management_Systen.Models.ServiceProvider>

@{
    ViewData["Title"] = "Service Providers";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between mb-3">
        <h2>Service Provider Management</h2>
        <a asp-action="Create" class="btn btn-primary btn-lg">
            <i class="bi bi-plus-lg"></i> Add Service Provider
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Company Name</th>
                        <th>Contact Person</th>
                        <th>Email</th>
                        <th>Mobile</th>
                        <th>Service Type</th>
                        <th>Approval Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CompanyName</td>
                            <td>@item.ContactPerson</td>
                            <td>@item.Email</td>
                            <td>@item.MobileNumber</td>
                            <td>@item.ServiceType</td>
                            <td>
                                @if (item.ApprovalStatus == "Approved")
                                {
                                    <span class="badge bg-success">@item.ApprovalStatus</span>
                                }
                                else if (item.ApprovalStatus == "Pending")
                                {
                                    <span class="badge bg-warning">@item.ApprovalStatus</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@item.ApprovalStatus</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                @if (User.IsInRole("Head") && item.ApprovalStatus == "Pending")
                                {
                                    <form method="post" asp-action="Approve" asp-route-id="@item.Id" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-success btn-sm">
                                            <i class="bi bi-check"></i> Approve
                                        </button>
                                    </form>
                                }
                                <form method="post" asp-action="Delete" asp-route-id="@item.Id" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure?')">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info mt-3">
            No service providers found. <a asp-action="Create">Add your first service provider</a>
        </div>
    }
</div>
