@page
@model Equipmenet_Management_Systen.Pages.Maintenance.IndexModel
@using Equipmenet_Management_Systen.Models
@using Microsoft.AspNetCore.Identity

@{
    ViewData["Title"] = "Maintenance Management";
}

@inject UserManager<ApplicationUser> UserManager

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h3">🔨 Maintenance Management</h1>
            <p class="text-muted">Manage equipment maintenance requests</p>
        </div>
        <div class="col-md-4 text-end">
            @if (Model.UserRoles?.Contains("User") == true || Model.UserRoles?.Contains("Head") == true)
            {
                <a asp-page="/Maintenance/Create" class="btn btn-success">➕ Request Maintenance</a>
            }
        </div>
    </div>

    <!-- Filters -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form method="get" class="row g-3">
                        <div class="col-md-6">
                            <input type="text" name="searchTerm" class="form-control" placeholder="Search equipment..." value="@Model.SearchTerm" />
                        </div>

                        <div class="col-md-4">
                            <select name="statusFilter" class="form-select">
                                <option value="">-- All Status --</option>
                                <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Pending</option>
                                <option value="Approved" selected="@(Model.StatusFilter == "Approved")">Approved</option>
                                <option value="In Progress" selected="@(Model.StatusFilter == "In Progress")">In Progress</option>
                                <option value="Completed" selected="@(Model.StatusFilter == "Completed")">Completed</option>
                                <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">Rejected</option>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100">🔍 Search</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Maintenance Requests List -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        Maintenance Requests
                        <span class="badge bg-primary ms-2">@Model.MaintenanceRequests.Count</span>
                    </h5>
                </div>
                <div class="card-body p-0">
                    @if (Model.MaintenanceRequests.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Equipment</th>
                                        <th>Description</th>
                                        <th>Requested Date</th>
                                        <th>Status</th>
                                        <th>Service Provider</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var request in Model.MaintenanceRequests)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@request.Equipment?.EquipmentName</strong>
                                                <br />
                                                <small class="text-muted">@request.Equipment?.EquipmentCode</small>
                                            </td>
                                            <td>
                                                <small>@(request.Description.Length > 50 ? request.Description.Substring(0, 50) + "..." : request.Description)</small>
                                            </td>
                                            <td>
                                                <small>@request.RequestDate.ToString("MMM dd, yyyy")</small>
                                            </td>
                                            <td>
                                                @if (request.Status == "Pending")
                                                {
                                                    <span class="badge bg-warning text-dark">Pending</span>
                                                }
                                                else if (request.Status == "Approved")
                                                {
                                                    <span class="badge bg-info">Approved</span>
                                                }
                                                else if (request.Status == "In Progress")
                                                {
                                                    <span class="badge bg-primary">In Progress</span>
                                                }
                                                else if (request.Status == "Completed")
                                                {
                                                    <span class="badge bg-success">Completed</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Rejected</span>
                                                }
                                            </td>
                                            <td>
                                                @(request.AssignedProvider?.CompanyName ?? "Not Assigned")
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <a asp-page="/Maintenance/Details" asp-route-id="@request.Id" class="btn btn-outline-primary">
                                                        👁️ View
                                                    </a>

                                                    @if ((Model.UserRoles?.Contains("Head") == true || Model.UserRoles?.Contains("PlatformHead") == true) && request.Status == "Pending")
                                                    {
                                                        <form method="post" asp-page-handler="Approve" asp-route-id="@request.Id" style="display:inline;">
                                                            <button type="submit" class="btn btn-outline-success btn-sm">✓ Approve</button>
                                                        </form>
                                                        <form method="post" asp-page-handler="Reject" asp-route-id="@request.Id" style="display:inline;">
                                                            <button type="submit" class="btn btn-outline-danger btn-sm">✗ Reject</button>
                                                        </form>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info m-3">
                            No maintenance requests found.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics -->
    @if (Model.UserRoles?.Contains("PlatformHead") == true || Model.UserRoles?.Contains("Head") == true)
    {
        <div class="row mt-4">
            <div class="col-md-4">
                <div class="card bg-light">
                    <div class="card-body text-center">
                        <h5>Pending</h5>
                        <h2 class="text-warning">@Model.MaintenanceRequests.Count(m => m.Status == "Pending")</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-light">
                    <div class="card-body text-center">
                        <h5>In Progress</h5>
                        <h2 class="text-info">@Model.MaintenanceRequests.Count(m => m.Status == "In Progress")</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-light">
                    <div class="card-body text-center">
                        <h5>Completed</h5>
                        <h2 class="text-success">@Model.MaintenanceRequests.Count(m => m.Status == "Completed")</h2>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
