@page "{id:int}"
@model Equipmenet_Management_Systen.Pages.Equipment.EditModel
@using Equipmenet_Management_Systen.Models

@{
    ViewData["Title"] = "Edit Equipment";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h3">✏️ Edit Equipment</h1>
            <p class="text-muted">Update equipment information</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-page="./Index" class="btn btn-outline-secondary">← Back to Equipment</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Edit Equipment Details</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="Equipment.Id" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Equipment.EquipmentName" class="form-label">Equipment Name *</label>
                                <input asp-for="Equipment.EquipmentName" class="form-control" required />
                                <span asp-validation-for="Equipment.EquipmentName" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Equipment.EquipmentCode" class="form-label">Equipment Code *</label>
                                <input asp-for="Equipment.EquipmentCode" class="form-control" required />
                                <span asp-validation-for="Equipment.EquipmentCode" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Equipment.Description" class="form-label">Description</label>
                            <textarea asp-for="Equipment.Description" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Equipment.DepartmentId" class="form-label">Department *</label>
                                <select asp-for="Equipment.DepartmentId" asp-items="Model.DepartmentList" class="form-select" required>
                                </select>
                                <span asp-validation-for="Equipment.DepartmentId" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Equipment.ServiceProviderId" class="form-label">Service Provider</label>
                                <select asp-for="Equipment.ServiceProviderId" asp-items="Model.ServiceProviderList" class="form-select">
                                    <option value="">-- None --</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Equipment.PurchaseDate" class="form-label">Purchase Date</label>
                                <input asp-for="Equipment.PurchaseDate" type="date" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Equipment.Location" class="form-label">Location</label>
                                <input asp-for="Equipment.Location" class="form-control" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Equipment.Value" class="form-label">Value (₹)</label>
                                <input asp-for="Equipment.Value" type="number" class="form-control" step="0.01" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Equipment.Status" class="form-label">Status</label>
                                <select asp-for="Equipment.Status" class="form-select">
                                    <option value="Active">Active</option>
                                    <option value="Inactive">Inactive</option>
                                    <option value="Maintenance">Under Maintenance</option>
                                    <option value="Disposed">Disposed</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Equipment.AssignedUserId" class="form-label">Assign To User</label>
                                <select asp-for="Equipment.AssignedUserId" asp-items="Model.UserList" class="form-select">
                                    <option value="">-- None --</option>
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Equipment.WarrantyExpiryDate" class="form-label">Warranty Expiry</label>
                                <input asp-for="Equipment.WarrantyExpiryDate" type="date" class="form-control" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Equipment.ManufacturerName" class="form-label">Manufacturer</label>
                                <input asp-for="Equipment.ManufacturerName" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Equipment.ManufacturerModel" class="form-label">Model</label>
                                <input asp-for="Equipment.ManufacturerModel" class="form-control" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="Equipment.SerialNumber" class="form-label">Serial Number</label>
                                <input asp-for="Equipment.SerialNumber" class="form-control" />
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Save Changes
                            </button>
                            <a asp-page="./Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">📋 Summary</h5>
                </div>
                <div class="card-body">
                    <p><strong>Code:</strong> @Model.Equipment.EquipmentCode</p>
                    <p><strong>Department:</strong> @(Model.Equipment.Department?.Name ?? "N/A")</p>
                    <p><strong>Status:</strong> <span class="badge bg-info">@Model.Equipment.Status</span></p>
                    <p><strong>Value:</strong> ₹@Model.Equipment.Value?.ToString("N2")</p>
                    <hr />
                    <p class="text-muted small mb-0">
                        Last updated: @Model.Equipment.UpdatedAt?.ToString("MMM dd, yyyy hh:mm tt")
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
