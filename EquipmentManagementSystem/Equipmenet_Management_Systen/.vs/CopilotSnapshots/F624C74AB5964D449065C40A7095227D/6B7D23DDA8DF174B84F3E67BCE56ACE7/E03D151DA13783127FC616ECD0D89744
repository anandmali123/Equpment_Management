@{
    ViewData["Title"] = "Equipment Management System";
}

<div style="background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%); min-height: 100vh; display: flex; align-items: center;">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 text-white">
                <h1 class="display-4 fw-bold mb-4">Equipment Management System</h1>
                <p class="lead mb-4">
                    A comprehensive solution for managing equipment calibration, maintenance schedules, 
                    and service providers with role-based access control and automated notifications.
                </p>

                <div class="features mb-4">
                    <div class="feature-item mb-3">
                        <i class="bi bi-check-circle" style="font-size: 24px; color: #3498db; margin-right: 10px;"></i>
                        <span>Real-time Calibration Tracking</span>
                    </div>
                    <div class="feature-item mb-3">
                        <i class="bi bi-check-circle" style="font-size: 24px; color: #3498db; margin-right: 10px;"></i>
                        <span>Preventive Maintenance Management</span>
                    </div>
                    <div class="feature-item mb-3">
                        <i class="bi bi-check-circle" style="font-size: 24px; color: #3498db; margin-right: 10px;"></i>
                        <span>Service Provider Management</span>
                    </div>
                    <div class="feature-item mb-3">
                        <i class="bi bi-check-circle" style="font-size: 24px; color: #3498db; margin-right: 10px;"></i>
                        <span>Role-Based Access Control</span>
                    </div>
                    <div class="feature-item mb-3">
                        <i class="bi bi-check-circle" style="font-size: 24px; color: #3498db; margin-right: 10px;"></i>
                        <span>Automated Email Notifications</span>
                    </div>
                </div>

                <div class="d-flex gap-3">
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </a>
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-light btn-lg">
                        <i class="bi bi-person-plus"></i> Register
                    </a>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card bg-dark border-secondary" style="box-shadow: 0 10px 30px rgba(0,0,0,0.3);">
                    <div class="card-body p-5">
                        <h5 class="card-title text-white mb-4"><i class="bi bi-info-circle"></i> System Overview</h5>

                        <div class="mb-4">
                            <h6 class="text-info"><i class="bi bi-gear"></i> Core Features</h6>
                            <ul class="list-unstyled text-secondary">
                                <li><i class="bi bi-arrow-right"></i> Equipment Master Data Management</li>
                                <li><i class="bi bi-arrow-right"></i> Calibration Schedule & Tracking</li>
                                <li><i class="bi bi-arrow-right"></i> Maintenance Request Workflow</li>
                                <li><i class="bi bi-arrow-right"></i> Service Provider Approval Process</li>
                            </ul>
                        </div>

                        <div class="mb-4">
                            <h6 class="text-info"><i class="bi bi-person"></i> User Roles</h6>
                            <ul class="list-unstyled text-secondary" style="font-size: 14px;">
                                <li><i class="bi bi-arrow-right"></i> User, Department Head</li>
                                <li><i class="bi bi-arrow-right"></i> Maintenance Incharge, Platform Head</li>
                                <li><i class="bi bi-arrow-right"></i> Purchase Manager, Client Head</li>
                            </ul>
                        </div>

                        <div class="alert alert-info" style="background-color: #2c5aa0 !important; border-color: #3498db;">
                            <small><strong>📧 Note:</strong> Configure SMTP settings in appsettings.json for email notifications</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .feature-item {
        display: flex;
        align-items: center;
        font-size: 16px;
    }

    .btn-lg {
        padding: 12px 30px;
        font-size: 16px;
        font-weight: 500;
    }
</style>
