@page
@model Equipmenet_Management_Systen.Pages.Dashboard.IndexModel
@using Microsoft.AspNetCore.Identity
@using Equipmenet_Management_Systen.Models

@{
    ViewData["Title"] = "Dashboard";
}

@inject UserManager<ApplicationUser> UserManager

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Welcome, @Model.User?.FullName!</h1>
            <p class="text-muted">Logged in as: <strong>@Model.User?.Email</strong></p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-page="/Account/Manage/Index" class="btn btn-outline-primary me-2">Profile</a>
            <form method="post" style="display:inline;">
                <button type="submit" asp-page-handler="Logout" class="btn btn-danger">Sign Out</button>
            </form>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3">
            <div class="card bg-primary text-white mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total Equipment</h5>
                    <h2>@Model.TotalEquipment</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white mb-3">
                <div class="card-body">
                    <h5 class="card-title">Active Equipment</h5>
                    <h2>@Model.ActiveEquipment</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white mb-3">
                <div class="card-body">
                    <h5 class="card-title">Pending Maintenance</h5>
                    <h2>@Model.PendingMaintenance</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white mb-3">
                <div class="card-body">
                    <h5 class="card-title">Overdue Calibration</h5>
                    <h2>@Model.OverdueCalibration</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Recent Maintenance Requests</h5>
                </div>
                <div class="card-body">
                    @if (Model.RecentRequests?.Count > 0)
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var request in Model.RecentRequests)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@request.Equipment?.Name</strong>
                                        <br />
                                        <small class="text-muted">@request.RequestDate.ToShortDateString()</small>
                                    </div>
                                    <span class="badge bg-warning">@request.Status</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">No maintenance requests</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <a asp-page="/Equipment/Index" class="btn btn-primary btn-sm mb-2">View Equipment</a>
                    <a asp-page="/Equipment/Create" class="btn btn-success btn-sm mb-2">Add New Equipment</a>
                    <a asp-page="/Maintenance/Index" class="btn btn-warning btn-sm mb-2">Maintenance Requests</a>
                    <a asp-page="/Department/Index" class="btn btn-info btn-sm mb-2">Departments</a>
                </div>
            </div>
        </div>
    </div>
</div>
